TELEGRAM_BOT_TOKEN=

# Optional: additional named bots for per-group personas. Each group in
# ~/.config/nanoclaw/telegram-bots.json can pick one. The suffix after
# TELEGRAM_BOT_TOKEN_ becomes the bot ID (lowercased), e.g. the line below
# defines a bot with ID "wiki_tutor". Groups not listed in the JSON file
# route to the default bot. Omit entirely if you only use one bot.
# TELEGRAM_BOT_TOKEN_WIKI_TUTOR=
